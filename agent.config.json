{
  "provider": "openrouter",
  "model": "anthropic/claude-opus-4.7",
  "systemPrompt": "",
  "maxSteps": 20,
  "maxCost": 1.0,
  "sessionDir": ".sessions",
  "showBanner": true,
  "slashCommands": true,
  "display": {
    "toolDisplay": "grouped",
    "reasoning": false,
    "inputStyle": "block"
  },
  "plugins": {
    "enabled": true,
    "directories": ["./plugins", "~/.config/crobot/plugins"],
    "permissions": ["file_read", "file_write", "shell", "tool_call", "send_message"]
  }
}