{
  "provider": "openrouter",
  "model": "deepseek/deepseek-v4-flash",
  "systemPrompt": "",
  "sessionDir": ".sessions",
  "showBanner": true,
  "slashCommands": true,
  "display": {
    "toolDisplay": "grouped",
    "reasoning": false,
    "inputStyle": "block"
  },
  "plugins": {
    "enabled": true,
    "directories": ["./plugins", "~/.config/crobot/plugins"],
    "permissions": ["file_read", "file_write", "shell", "tool_call", "send_message"]
  }
}